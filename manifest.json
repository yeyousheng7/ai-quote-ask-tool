{
  "manifest_version": 3,
  "name": "AI Quote Annotation",
  "version": "0.3.2",
  "description": "Add lightweight quote annotation threads to supported AI conversations.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "AI 提问助手",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "src/theme.js",
        "src/storage.js",
        "src/sanitize.js",
        "src/provider-input-blocker.js",
        "src/scroll-lock.js",
        "src/providers/chatgpt-dom.js",
        "src/providers/chatgpt.js",
        "src/providers/gemini-dom.js",
        "src/providers/gemini.js",
        "src/providers/deepseek-dom.js",
        "src/providers/deepseek.js",
        "src/provider.js",
        "src/sidebar.js",
        "src/content.js"
      ],
      "css": ["src/theme.css", "src/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
